APP_NAME="Prazzu Tools"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR
APP_TIMEZONE=America/Sao_Paulo

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# Por padrão, o Laravel usa database/database.sqlite.
# Use um caminho absoluto somente quando o ambiente exigir.
# DB_DATABASE=C:\xampp\htdocs\prazzu-tools\database\database.sqlite

# Configuração local segura antes das migrations.
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="nao-responda@prazzu.com.br"
MAIL_FROM_NAME="${APP_NAME}"
# Em desenvolvimento e testes mantenha MAIL_MAILER=log ou array para impedir envios reais.
# Em produção configure SMTP/serviço transacional e use QUEUE_CONNECTION=database ou redis.

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

BRASIL_API_BASE_URL=https://brasilapi.com.br/api
BRASIL_API_CONNECT_TIMEOUT=3
BRASIL_API_TIMEOUT=8

ANALYTICS_ENABLED=true
ANALYTICS_ASYNC=false
ANALYTICS_CAPTURE_PAGE_VIEWS=true
ANALYTICS_SESSION_TIMEOUT_MINUTES=30
ANALYTICS_VISITOR_COOKIE_DAYS=730
ANALYTICS_RETENTION_DAYS=730

# Analytics
ANALYTICS_ENABLED=true
ANALYTICS_RETENTION_DAYS=730
ANALYTICS_DASHBOARD_CACHE_SECONDS=60
ANALYTICS_PRUNE_CHUNK_SIZE=1000

# Política comercial: launch_free (lançamento gratuito) ou monetized (planos e limites ativos)
PRAZZU_COMMERCIAL_MODE=launch_free

# Operação e segurança
SECURITY_CSP_ENABLED=false
SECURITY_CONTENT_POLICY="default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; script-src 'self'; font-src 'self' data:; connect-src 'self'; frame-ancestors 'self'; base-uri 'self'; form-action 'self'"
SECURITY_HSTS="max-age=31536000; includeSubDomains"
RETENTION_APPLICATION_LOGS_DAYS=14
RETENTION_TEMPORARY_FILES_HOURS=24
RETENTION_FAILED_JOBS_DAYS=30
BACKUP_FREQUENCY=daily
BACKUP_RETENTION_DAYS=30
RECOVERY_POINT_OBJECTIVE_HOURS=24
RECOVERY_TIME_OBJECTIVE_HOURS=4
